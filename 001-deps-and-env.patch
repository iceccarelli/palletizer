+# ---------------------------------------------------------------------------
+# Palletizer web (Next.js) — environment
+# Copy to web/.env.local for local dev. Set the same vars in Vercel Project
+# Settings → Environment Variables for production. NEVER commit real secrets.
+# ---------------------------------------------------------------------------
+
+# Public site URL (used to build success/cancel/return URLs server-side).
+NEXT_PUBLIC_SITE_URL=https://palletizer-app.vercel.app
+
+# --- Supabase ---
+NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
+NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
+# Server-only. Bypasses RLS. Used by the Stripe webhook + /api/leads. NEVER expose.
+SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
+
+# --- Stripe ---
+STRIPE_SECRET_KEY=sk_test_...
+STRIPE_WEBHOOK_SECRET=whsec_...
+NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
+# Stripe Price IDs (create in Stripe Dashboard: recurring, annual). One per currency.
+NEXT_PUBLIC_STRIPE_PRICE_PRO_CAD=price_...
+NEXT_PUBLIC_STRIPE_PRICE_PRO_USD=price_...
+
+# --- n8n handoff (Rank 2). Optional: if unset, forwarding is skipped. ---
+N8N_WEBHOOK_URL=
+N8N_WEBHOOK_TOKEN=
+
+# --- Later ranks ---
+RESEND_API_KEY=
