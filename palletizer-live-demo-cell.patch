   const [csvData, setCsvData] = useState<any[]>([]);
   const [fileName, setFileName] = useState('');
 
+  // --- Live execution state: the arm builds the plan pick-by-pick ---
+  const [anim, setAnim] = useState<RobotAnim>({ activeIndex: -1, progress: 0, placedCount: 0 });
+  const [playing, setPlaying] = useState(false);
+  const [speed, setSpeed] = useState(1);
+  const raf = useRef<number | null>(null);
+
+  // RAF clock — identical pacing to the Robot Execution demo. Advances the
+  // active placement's progress; when it completes, the box "lands" (via
+  // visibleCount) and the arm moves to the next pick. Motion follows the real
+  // optimizer coordinates, so what you watch is what the plan says.
+  useEffect(() => {
+    if (!playing || !plan) return;
+    let last = performance.now();
+    const tick = (now: number) => {
+      const dt = Math.min(0.05, (now - last) / 1000);
+      last = now;
+      setAnim((a) => {
+        if (a.placedCount >= plan.boxes.length) {
+          setPlaying(false);
+          return { ...a, activeIndex: -1 };
+        }
+        const active = a.activeIndex === -1 ? a.placedCount : a.activeIndex;
+        let progress = a.progress + dt * 0.5 * speed;
+        let placed = a.placedCount;
+        let nextActive = active;
+        if (progress >= 1) {
+          placed = active + 1;
+          progress = 0;
+          nextActive = placed < plan.boxes.length ? placed : -1;
+        }
+        return { activeIndex: nextActive, progress, placedCount: placed };
+      });
+      raf.current = requestAnimationFrame(tick);
+    };
+    raf.current = requestAnimationFrame(tick);
+    return () => {
+      if (raf.current) cancelAnimationFrame(raf.current);
+    };
+  }, [playing, plan, speed]);
+
   const handleFileUpload = (e: React.ChangeEvent<HTMLInputElement>) => {
     const file = e.target.files?.[0];
     if (!file) return;
