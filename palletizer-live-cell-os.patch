+      </div>
+      <div className="h-44 overflow-y-auto space-y-1 font-mono text-[10.5px] leading-relaxed pr-1">
+        {sim.events.map((e, i) => (
+          <div key={i} className={color(e.kind)}>
+            <span className="text-white/25">[{e.t.toFixed(1)}s]</span> {e.text}
+          </div>
+        ))}
+        <div ref={endRef} />
+      </div>
