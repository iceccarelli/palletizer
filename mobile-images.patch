@@ -0,0 +1,43 @@
+"use client";
+
+import Image from "next/image";
+import { useEffect, useState } from "react";
+
+// 12 professional landing images — cycle behind the hero, one every 4s.
+const SLIDES = [
+  "01-hero-palletizing-cell", "02-precision-gripper-ai", "03-ai-mixed-sku-pallet",
+  "04-one-codebase-any-robot", "05-global-fleet-command", "06-safety-first-collaboration",
+  "07-high-throughput-120-cycles", "08-robotinterface-under-100-lines", "09-food-beverage-sanitary",
+  "10-ecommerce-mixed-sku", "11-digital-twin-sim-to-real", "12-scale-to-global-fleets",
+].map((n) => `/landing/${n}.jpg`);
+
+const INTERVAL = 4000;
+
+export default function KenBurnsHero() {
+  const [i, setI] = useState(0);
+
+  useEffect(() => {
+    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
+    const t = setInterval(() => setI((p) => (p + 1) % SLIDES.length), INTERVAL);
+    return () => clearInterval(t);
+  }, []);
+
+  return (
+    <div className="absolute inset-0 overflow-hidden" aria-hidden="true">
+      {SLIDES.map((src, idx) => (
+        <div key={src} className={`kb-slide ${idx === i ? "kb-active" : ""}`}>
+          <Image
+            src={src}
+            alt=""
+            fill
+            priority={idx === 0}
+            sizes="100vw"
+            className="object-cover"
+          />
+        </div>
+      ))}
+      {/* legibility wash so hero copy stays readable over any frame */}
+      <div className="absolute inset-0 bg-gradient-to-b from-[#0f172a]/85 via-[#0f172a]/75 to-[#0f172a]/92" />
+    </div>
+  );
+}
