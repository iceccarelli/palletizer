+/* One canonical page container — same gutters for navbar, footer, every
+   section, at every breakpoint. Prevents mobile edge-misalignment. */
+@layer components {
+  .container-page {
+    @apply mx-auto max-w-7xl px-4 sm:px-6 lg:px-8;
+  }
+}
+
+/* Ken Burns slideshow (KenBurnsHero) — crossfade + slow zoom/pan. */
+.kb-slide { position: absolute; inset: 0; opacity: 0; transition: opacity 1.2s ease-in-out; }
+.kb-slide.kb-active { opacity: 1; }
+.kb-slide.kb-active img { animation: kenburns 5s ease-out both; }
+@keyframes kenburns {
+  from { transform: scale(1.06) translate(0, 0); }
+  to   { transform: scale(1.2) translate(-1.5%, -1.5%); }
+}
+@media (prefers-reduced-motion: reduce) {
+  .kb-slide { transition: none; }
+  .kb-slide.kb-active img { animation: none; }
+}
+
 :root {
   --background: 222.2 84% 4.9%;
   --foreground: 210 40% 98%;
