diff --git a/web/components/SwipeGallery.tsx b/web/components/SwipeGallery.tsx
new file mode 100644
index 0000000..b38b2b5
--- /dev/null
+++ b/web/components/SwipeGallery.tsx
@@ -0,0 +1,92 @@
+"use client";
+
+import Image from "next/image";
+import { useState } from "react";
+import { motion, AnimatePresence, type PanInfo } from "framer-motion";
+import { ChevronLeft, ChevronRight } from "lucide-react";
+
+const CARDS = [
+  { src: "/landing/01-hero-palletizing-cell.jpg",        title: "Production palletizing cell",   blurb: "Deterministic control, full telemetry, production-grade safety." },
+  { src: "/landing/02-precision-gripper-ai.jpg",         title: "AI precision gripping",         blurb: "Vacuum and pressure feedback, every pick vision-gated." },
+  { src: "/landing/03-ai-mixed-sku-pallet.jpg",          title: "Mixed-SKU optimization",        blurb: "Stable, interlocked, crush-safe stacks at 90%+ fill." },
+  { src: "/landing/04-one-codebase-any-robot.jpg",       title: "One codebase, any robot",       blurb: "UR, FANUC, KUKA, ABB — the same engine drives them all." },
+  { src: "/landing/05-global-fleet-command.jpg",         title: "Fleet command center",          blurb: "Every cell in your operation on one pane of glass." },
+  { src: "/landing/06-safety-first-collaboration.jpg",   title: "Safety-first by design",        blurb: "Watchdog latches E-stop in 2.5s — it never moves blind." },
+  { src: "/landing/07-high-throughput-120-cycles.jpg",   title: "High throughput",               blurb: "Up to 120 cycles/min on capable hardware." },
+  { src: "/landing/08-robotinterface-under-100-lines.jpg", title: "Add an arm in <100 lines",    blurb: "Subclass RobotInterface; planner and safety stay unchanged." },
+  { src: "/landing/09-food-beverage-sanitary.jpg",       title: "Food & beverage ready",         blurb: "Sanitary layouts and audit trails for regulated lines." },
+  { src: "/landing/10-ecommerce-mixed-sku.jpg",          title: "E-commerce mixed-SKU",          blurb: "High-mix chaos planned in milliseconds." },
+  { src: "/landing/11-digital-twin-sim-to-real.jpg",     title: "Digital twin, sim-to-real",     blurb: "Validate offline, then deploy to hardware with confidence." },
+  { src: "/landing/12-scale-to-global-fleets.jpg",       title: "Scale to global fleets",        blurb: "From a single cell to a worldwide operation." },
+];
+
+export default function SwipeGallery() {
+  const [[i, dir], set] = useState<[number, number]>([0, 0]);
+  const go = (d: number) => set([(i + d + CARDS.length) % CARDS.length, d]);
+
+  const onDragEnd = (_e: unknown, info: PanInfo) => {
+    if (info.offset.x < -80 || info.velocity.x < -450) go(1);
+    else if (info.offset.x > 80 || info.velocity.x > 450) go(-1);
+  };
+
+  const c = CARDS[i];
+
+  return (
+    <section className="section-padding border-y border-white/10">
+      <div className="container-page">
+        <div className="text-center mb-10">
+          <div className="text-xs uppercase tracking-[3px] text-primary mb-3">Explore the platform</div>
+          <h2 className="text-3xl sm:text-4xl md:text-5xl font-semibold tracking-tighter">
+            Swipe through what it does
+          </h2>
+        </div>
+
+        <div className="relative max-w-xl mx-auto">
+          <div className="relative h-[440px] sm:h-[500px] select-none">
+            <AnimatePresence initial={false} custom={dir} mode="popLayout">
+              <motion.article
+                key={i}
+                custom={dir}
+                drag="x"
+                dragConstraints={{ left: 0, right: 0 }}
+                dragElastic={0.55}
+                onDragEnd={onDragEnd}
+                initial={{ x: dir > 0 ? 320 : -320, opacity: 0, rotate: dir > 0 ? 5 : -5 }}
+                animate={{ x: 0, opacity: 1, rotate: 0 }}
+                exit={{ x: dir > 0 ? -320 : 320, opacity: 0, rotate: dir > 0 ? -5 : 5 }}
+                transition={{ type: "spring", stiffness: 320, damping: 32 }}
+                className="absolute inset-0 rounded-card overflow-hidden border border-white/10 bg-[#0b1222] shadow-2xl shadow-black/40 cursor-grab active:cursor-grabbing"
+              >
+                <div className="relative h-3/5">
+                  <Image src={c.src} alt={c.title} fill sizes="(max-width:640px) 100vw, 576px" className="object-cover pointer-events-none" />
+                </div>
+                <div className="p-6">
+                  <div className="font-mono text-xs text-primary tracking-[2px] mb-2">
+                    {String(i + 1).padStart(2, "0")} / {CARDS.length}
+                  </div>
+                  <h3 className="text-xl font-semibold tracking-tight mb-2">{c.title}</h3>
+                  <p className="text-white/60 text-sm leading-relaxed">{c.blurb}</p>
+                </div>
+              </motion.article>
+            </AnimatePresence>
+          </div>
+
+          <div className="flex items-center justify-center gap-4 mt-6">
+            <button onClick={() => go(-1)} aria-label="Previous card" className="h-11 w-11 inline-flex items-center justify-center rounded-full border border-white/15 hover:bg-white/5 transition">
+              <ChevronLeft className="w-5 h-5" />
+            </button>
+            <div className="flex gap-1.5" aria-hidden="true">
+              {CARDS.map((_, idx) => (
+                <span key={idx} className={`h-1.5 rounded-full transition-all ${idx === i ? "w-6 bg-primary" : "w-1.5 bg-white/25"}`} />
+              ))}
+            </div>
+            <button onClick={() => go(1)} aria-label="Next card" className="h-11 w-11 inline-flex items-center justify-center rounded-full border border-white/15 hover:bg-white/5 transition">
+              <ChevronRight className="w-5 h-5" />
+            </button>
+          </div>
+          <p className="text-center text-white/40 text-xs mt-3 sm:hidden">Swipe cards left or right</p>
+        </div>
+      </div>
+    </section>
+  );
+}
