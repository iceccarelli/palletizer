+                  <Link
+                    href="/contact"
+                    onClick={closeAll}
+                    className="py-3 text-center border border-emerald-500/50 text-emerald-300 rounded-2xl font-semibold text-sm"
+                  >
+                    Request a pilot
+                  </Link>
+                </div>
+              </div>
+            </motion.div>
+          )}
+        </AnimatePresence>
+      </div>
     </motion.nav>
   );
 }
